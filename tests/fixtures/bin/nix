#!/usr/bin/env bash

set -euo pipefail

arguments=" $* "
last=${!#}
fixtures=${NIXOS_UPDATE_CHECKER_FIXTURES:?}
if [[ -n "${FAKE_INVOCATIONS:-}" ]]; then
  printf '%s\n' "$*" >>"$FAKE_INVOCATIONS"
fi

if [[ "$arguments" == *" flake update "* ]]; then
  while (($#)); do
    if [[ "$1" == "--output-lock-file" ]]; then
      install -m 0644 "$fixtures/flake.lock" "$2"
      exit 0
    fi
    shift
  done
elif [[ "$arguments" == *" config show "* ]]; then
  echo '{"substituters":{"value":[]}}'
elif [[ "$arguments" == *" eval "* && "$arguments" == *" --json "* ]]; then
  if [[ "$arguments" == *" --reference-lock-file "* ]]; then
    if [[ ${FAKE_DISCOVERY_FAILURE:-} == 1 ]]; then
      echo "fixture configuration is invalid" >&2
      exit 2
    fi
    if [[ ${FAKE_DISCOVERY_BLOCK:-} == 1 ]]; then
      : >"${FAKE_DISCOVERY_MARKER:?}"
      sleep 2
    fi
    firefox_version=2.0
    firefox_path=/nix/store/ffffffffffffffffffffffffffffffff-firefox-2.0
    glibc_path=/nix/store/gggggggggggggggggggggggggggggggg-glibc-2.40
    active_version=2.0
    active_path=/nix/store/nnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnn-active-option-2.0
    if [[ ${FAKE_UNCHANGED_PACKAGES:-} == 1 ]]; then
      firefox_version=1.0
      firefox_path=/nix/store/aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa-firefox-1.0
      glibc_path=/nix/store/bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb-glibc-2.40
      active_version=1.0
      active_path=/nix/store/mmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmm-active-option-1.0
    fi
    cat <<EOF
{"system":{"drvPath":"/nix/store/candidate.drv","storePath":"${FAKE_CANDIDATE_SYSTEM:?}"},"packages":[{"source":"environment.systemPackages","label":"Firefox","name":"firefox","version":"$firefox_version","storePath":"$firefox_path","drvPath":"/nix/store/firefox.drv","position":"fixture"},{"source":"core:systemd","label":"systemd","name":"glibc","version":"2.40","storePath":"$glibc_path","drvPath":"/nix/store/glibc.drv","position":"fixture"},{"source":"option:services.active.package","label":"Active option package","name":"active-option","version":"$active_version","storePath":"$active_path","drvPath":"/nix/store/active-option.drv","position":"fixture"},{"source":"option:services.fixture.package","label":"Unused option package","name":"unused-option-package","version":"","storePath":"/nix/store/kkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkk-unused-option-package","drvPath":"/nix/store/unused-option-package.drv","position":"fixture"},{"source":"option:programs.firefox.package","label":"Unused Firefox option","name":"firefox","version":"$firefox_version","storePath":"/nix/store/llllllllllllllllllllllllllllllll-firefox-option-hint","drvPath":"/nix/store/firefox-option-hint.drv","position":"fixture"}]}
EOF
  elif [[ "$last" == *"#nixosConfigurations" ]]; then
    echo '[{"name":"desktop","hostName":"fixture"}]'
  else
    cat <<EOF
{"system":{"drvPath":"${FAKE_DECLARED_DERIVER:-/nix/store/declared.drv}","storePath":"${FAKE_RUNNING_SYSTEM:?}"},"packages":[{"source":"environment.systemPackages","label":"Firefox","name":"firefox","version":"1.0","storePath":"/nix/store/aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa-firefox-1.0","drvPath":"/nix/store/firefox.drv","position":"fixture"},{"source":"core:systemd","label":"systemd","name":"glibc","version":"2.40","storePath":"/nix/store/bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb-glibc-2.40","drvPath":"/nix/store/glibc.drv","position":"fixture"},{"source":"option:services.active.package","label":"Active option package","name":"active-option","version":"1.0","storePath":"/nix/store/mmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmm-active-option-1.0","drvPath":"/nix/store/active-option.drv","position":"fixture"},{"source":"option:services.fixture.package","label":"Unused option package","name":"unused-option-package","version":"","storePath":"/nix/store/oooooooooooooooooooooooooooooooo-unused-option-package","drvPath":"/nix/store/unused-option-package.drv","position":"fixture"},{"source":"option:programs.firefox.package","label":"Unused Firefox option","name":"firefox","version":"1.0","storePath":"/nix/store/pppppppppppppppppppppppppppppppp-firefox-option-hint","drvPath":"/nix/store/firefox-option-hint.drv","position":"fixture"}]}
EOF
  fi
elif [[ "$arguments" == *" eval "* && "$arguments" == *" --raw "* ]]; then
  if [[ "$arguments" == *" --reference-lock-file "* ]]; then
    echo /nix/store/candidate.drv
  else
    echo "${FAKE_DECLARED_DERIVER:-/nix/store/declared.drv}"
  fi
elif [[ "$arguments" == *" build "* && "$arguments" == *" --dry-run "* ]]; then
  echo 'this path will be built: /nix/store/zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzz-firefox.drv' >&2
  echo '[]'
elif [[ "$arguments" == *" build "* ]]; then
  mkdir -p "${FAKE_CANDIDATE_SYSTEM:?}"
  echo "${FAKE_CANDIDATE_SYSTEM:?}"
elif [[ "$arguments" == *" path-info "* && "$arguments" == *" --derivation "* ]]; then
  if [[ "$last" == "${FAKE_BOOT_SYSTEM:-}" ]]; then
    echo "${FAKE_BOOT_DERIVER:-/nix/store/boot.drv}"
  elif [[ "$last" == "${FAKE_RUNNING_SYSTEM:-}" ]]; then
    echo "${FAKE_RUNNING_DERIVER:-/nix/store/running.drv}"
  else
    echo /nix/store/candidate.drv
  fi
elif [[ "$arguments" == *" path-info "* ]]; then
  if [[ "$last" == "${FAKE_BOOT_SYSTEM:-}" || "$last" == "${FAKE_RUNNING_SYSTEM:-}" ]]; then
    cat "$fixtures/baseline-closure.json"
  elif [[ ${FAKE_METADATA_FAILURE:-} == 1 ]]; then
    echo '{"/nix/store/ffffffffffffffffffffffffffffffff-firefox-2.0":null}'
    exit 1
  elif [[ ${FAKE_UNCHANGED_PACKAGES:-} == 1 ]]; then
    cat "$fixtures/baseline-closure.json"
  else
    cat "$fixtures/candidate-closure.json"
  fi
else
  echo "Unexpected nix invocation: $*" >&2
  exit 1
fi
