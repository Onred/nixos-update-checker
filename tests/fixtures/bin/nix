#!/usr/bin/env bash

set -euo pipefail

arguments=" $* "
last=${!#}
fixtures=${NIXOS_UPDATE_CHECKER_FIXTURES:?}
work=${FAKE_WORK_DIRECTORY:-}

wait_for_file() {
  local path=$1
  local _
  for _ in {1..200}; do
    [[ -e "$path" ]] && return
    sleep 0.01
  done
  echo "Timed out waiting for fixture marker: $path" >&2
  exit 1
}

if [[ "$arguments" == *" eval "* && "$arguments" == *" --json "* ]]; then
  if [[ ${FAKE_VERIFY_PARALLEL:-} == 1 ]]; then
    wait_for_file "$work/update-started"
    touch "$work/eval-during-update"
  fi
  echo '[{"name":"desktop","hostName":"fixture"}]'
elif [[ "$arguments" == *" eval "* && "$arguments" == *" --raw "* ]]; then
  echo "${FAKE_DECLARED_DERIVER:-/nix/store/declared.drv}"
elif [[ "$arguments" == *" flake update "* ]]; then
  if [[ ${FAKE_VERIFY_PARALLEL:-} == 1 ]]; then
    touch "$work/update-started"
    wait_for_file "$work/eval-during-update"
  fi
  while (($#)); do
    if [[ "$1" == "--output-lock-file" ]]; then
      install -m 0644 "$fixtures/flake.lock" "$2"
      exit 0
    fi
    shift
  done
elif [[ "$arguments" == *" build "* ]]; then
  echo "${FAKE_CANDIDATE_SYSTEM:?}"
elif [[ "$arguments" == *" path-info "* && "$arguments" == *" --derivation "* ]]; then
  if [[ "$last" == "${FAKE_BOOT_SYSTEM:-}" ]]; then
    echo "${FAKE_BOOT_DERIVER:-/nix/store/boot.drv}"
  elif [[ "$last" == "${FAKE_RUNNING_SYSTEM:-}" ]]; then
    echo "${FAKE_RUNNING_DERIVER:-/nix/store/running.drv}"
  else
    echo /nix/store/candidate.drv
  fi
elif [[ "$arguments" == *" path-info "* ]]; then
  side=baseline
  if [[ "$last" == "${FAKE_CANDIDATE_SYSTEM:?}" ]]; then
    side=candidate
  fi
  if [[ -n "$work" ]]; then
    printf '%s\n' "$$" >"$work/path-info-$side.pid"
    printf '%s\n' "$side" >>"$work/path-info-calls"
  fi
  if [[ ${FAKE_VERIFY_PARALLEL:-} == 1 ]]; then
    touch "$work/path-info-$side-started"
    wait_for_file "$work/path-info-baseline-started"
    wait_for_file "$work/path-info-candidate-started"
  fi
  if [[ ${FAKE_FAIL_PATH_INFO:-} == "$side" ]]; then
    echo "Injected $side closure query failure" >&2
    exit 1
  fi
  if [[ "$side" == candidate ]]; then
    cat "$fixtures/candidate-closure.json"
  else
    cat "$fixtures/baseline-closure.json"
  fi
else
  echo "Unexpected nix invocation: $*" >&2
  exit 1
fi
